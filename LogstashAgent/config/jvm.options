## JVM configuration

################################################################
## IMPORTANT: JVM heap size
################################################################
##
## The heap size is automatically configured by Logstash
## based on the available memory when the JVM is not configured.
##
## If you want to override the default, uncomment the following
## lines and adjust them as necessary.
##
## Xms represents the initial size of total heap space
## Xmx represents the maximum size of total heap space

-Xms2g
-Xmx2g

################################################################
## Expert settings
################################################################
##
## All settings below here are considered expert settings. Do
## not adjust them unless you understand what you are doing. Do
## not edit anything below this section unless you know what you
## are doing.

# Disable explicit GC
-XX:+DisableExplicitGC

# Reduce the per-thread stack size
-Xss1m

# Force the JVM to use IPv4 stack
-Djava.net.preferIPv4Stack=true

# Set the locale to US English
-Dfile.encoding=UTF-8

# Use our provided JNA always versus the system one
-Djna.nosys=true

# Turn on JRuby invokedynamic
-Djruby.compile.invokedynamic=true

# Ensure UTF-8 encoding by default
-Dfile.encoding=UTF-8

# Use headless mode
-Djava.awt.headless=true

# Temporary directory
-Djava.io.tmpdir=/tmp

# GC logging options -- uncomment to enable
# -XX:+PrintGCDetails
# -XX:+PrintGCDateStamps
# -XX:+PrintGCTimeStamps
# -XX:+PrintClassHistogram
# -XX:+PrintTenuringDistribution
# -XX:+PrintGCApplicationStoppedTime

# Entropy source for randomness
-Djava.security.egd=file:/dev/urandom

# Copy the logging context from parent threads to children
-Dlog4j2.isThreadContextMapInheritable=true
